# Context Broker — Required API Keys
# Copy this file to config/credentials/.env and fill in your values.
# This file is gitignored. Never commit real credentials.

# LLM provider API key (used for summarization and the Imperator)
LLM_API_KEY=

# Embeddings provider API key (used for vector embeddings)
EMBEDDINGS_API_KEY=

# PostgreSQL password
POSTGRES_PASSWORD=

# Neo4j password (leave empty when using NEO4J_AUTH=none in docker-compose.yml)
NEO4J_PASSWORD=
