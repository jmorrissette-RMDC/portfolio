# Context Broker — Container Environment Variables
# Copy this file to .env and fill in your values.
# This file is gitignored. Never commit real credentials.
#
# API keys: LangChain reads standard env vars automatically.
# Set the ones your configured providers need.

# OpenAI (if using OpenAI for LLM or embeddings)
# OPENAI_API_KEY=sk-...

# Anthropic (if using Claude for LLM)
# ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL password (required)
POSTGRES_PASSWORD=
