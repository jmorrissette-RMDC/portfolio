# Context Broker — TE Configuration (Imperator / Cognitive)
# Copy this file to config/imperator.yml and customize.
# All settings are hot-reloadable (no restart needed).
#
# This file configures the Thought Engine — the Imperator and its
# cognitive apparatus. Infrastructure settings (database, queue, network)
# are in config.yml (the AE configuration).

# ============================================================
# Imperator Identity
# ============================================================
# REQ-001 §11.2: Identity and Purpose are baked in, not runtime config.
# They are expressed through the system prompt template.

imperator:
  identity: >
    I am the Context Broker's Imperator — the cognitive agent responsible
    for this context engineering and conversational memory service.
  purpose: >
    I manage conversations, assemble context windows, extract knowledge
    into a graph, and help users understand and operate the Context Broker.
  build_type: standard-tiered
  max_context_tokens: auto
  participant_id: imperator
  # admin_tools: false = read-only access to system state
  # admin_tools: true = can read/write config and run DB queries
  # NOTE: Requires container restart to take effect (Imperator graph compiled once).
  admin_tools: false

# ============================================================
# Inference Providers (per cognitive function)
# ============================================================
# Each function gets its own LLM slot. Different functions have different
# requirements — the Imperator needs a capable conversational model,
# summarization needs a fast/cheap model, extraction has its own needs.
#
# provider: "openai" (default) for OpenAI-compatible APIs,
#           "anthropic" for Anthropic's native API.
# API keys: set standard env vars (OPENAI_API_KEY, ANTHROPIC_API_KEY, etc.)
# in config/credentials/.env. LangChain reads them automatically.

inference:
  # Imperator conversational LLM
  imperator:
    # provider: openai           # "openai" (default) or "anthropic"
    base_url: http://context-broker-ollama:11434/v1
    model: qwen2.5:7b

  # Chunk summarization and archival consolidation LLM
  summarization:
    base_url: http://context-broker-ollama:11434/v1
    model: qwen2.5:7b

  # Memory extraction LLM (used by Mem0)
  extraction:
    base_url: http://context-broker-ollama:11434/v1
    model: qwen2.5:7b

# ============================================================
# Embeddings
# ============================================================

embeddings:
  # Note: no /v1 suffix — Infinity serves at /embeddings, not /v1/embeddings.
  base_url: http://context-broker-infinity:7997
  model: nomic-ai/nomic-embed-text-v1.5
  # Send raw text instead of token arrays. Required for Infinity, Ollama,
  # and most non-OpenAI providers. Set to true only for OpenAI directly.
  tiktoken_enabled: false
  check_embedding_ctx_length: false
  # Number of prior messages to include as context prefix when embedding
  context_window_size: 3

# ============================================================
# Reranker
# ============================================================

reranker:
  # "api" hits a /rerank endpoint — works with Infinity (local),
  #   Together, Cohere, Jina, Voyage, or any compatible provider.
  #   base_url includes any path prefix the provider requires.
  # "none" disables reranking (raw RRF scores used)
  provider: api
  base_url: http://context-broker-infinity:7997
  model: mixedbread-ai/mxbai-rerank-xsmall-v1
  top_n: 10

# ============================================================
# Build Types
# ============================================================
# Build types define context assembly strategies.
# Percentages must sum to <= 1.0 for each build type.
# max_context_tokens: "auto" queries the LLM provider, or set an explicit integer.
# fallback_tokens: used when auto-resolution fails.

build_types:

  passthrough:
    max_context_tokens: auto
    fallback_tokens: 8192

  standard-tiered:
    tier1_pct: 0.08
    tier2_pct: 0.20
    tier3_pct: 0.72
    max_context_tokens: auto
    fallback_tokens: 8192

  knowledge-enriched:
    tier1_pct: 0.05
    tier2_pct: 0.15
    tier3_pct: 0.50
    knowledge_graph_pct: 0.15
    semantic_retrieval_pct: 0.15
    max_context_tokens: auto
    fallback_tokens: 16000

# ============================================================
# Cognitive Tuning
# ============================================================
# These control cognitive behavior. All are hot-reloadable.

tuning:
  # Verbose pipeline logging (REQ-001 §4.8)
  verbose_logging: false

  # Context assembly
  chunk_size: 20
  consolidation_threshold: 3
  consolidation_keep_recent: 2
  summarization_temperature: 0.1
  trigger_threshold_percent: 0.1

  # Memory extraction
  extraction_max_chars: 90000

  # Memory confidence scoring — half-life decay by category (days)
  memory_half_lives:
    ephemeral: 3
    contextual: 14
    factual: 60
    historical: 365
    default: 30

  # Retrieval
  tokens_per_message_estimate: 150
  content_truncation_chars: 500
  query_truncation_chars: 200

  # Search
  rrf_constant: 60
  search_candidate_limit: 100
  recency_decay_days: 90
  recency_max_penalty: 0.2

  # Imperator
  imperator_max_iterations: 5
  imperator_temperature: 0.3
